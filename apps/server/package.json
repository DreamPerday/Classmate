{
  "name": "@classmate/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/cli/migrate.ts",
    "demo:seed": "tsx src/cli/seed.ts",
    "audit:artifacts": "tsx src/cli/audit-artifacts.ts"
  },
  "dependencies": {
    "@classmate/shared": "0.1.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.0",
    "nanoid": "^5.1.5",
    "openai": "^5.8.2",
    "pino": "^9.7.0",
    "zod": "^3.25.67",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
